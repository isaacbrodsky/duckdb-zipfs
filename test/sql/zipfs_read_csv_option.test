# name: test/sql/zipfs_read_csv_option.test
# description: test zipfs extension
# group: [sql]

require zipfs

statement ok
SET zipfs_split = "!!";

query III
SELECT * FROM 'zip://examples/a.zip!!a.csv'
----
1	2	3
4	5	6
7	8	9

query I
SELECT * FROM 'zip://examples/a.zip!!b.csv'
----
99
98
97

query I
SELECT * FROM 'zip://examples/a.zip!!/b.csv'
----
99
98
97

query I
SELECT hello FROM 'zip://examples/a.zip!!nested_dir/some_file.csv'
----
world

query I
SELECT hello FROM 'zip://examples/a.zip!!/nested_dir/some_file.csv'
----
world

query III
select * from read_csv('zip://examples/a.zip!!*.csv', union_by_name = true);
----
1	2	3
4	5	6
7	8	9
99	NULL	NULL
98	NULL	NULL
97	NULL	NULL

query III
select * from read_csv('zip://examples/a.zip!!/*.csv', union_by_name = true);
----
1	2	3
4	5	6
7	8	9
99	NULL	NULL
98	NULL	NULL
97	NULL	NULL

# No files match within the zip file
statement error
select * from read_csv('zip://examples/a.zip!!doesnt_exist*.csv');
----
No files found that match the pattern

# Invalid file within the zip file
statement error
select * from read_csv('zip://examples/a.zip!!doesnt_exist.csv');
----
Failed to find file

# No !! after .zip - falls through to DuckDB's core globber since the path
# lacks the configured zipfs_split. Error message varies by platform: on
# non-Windows the globber reports "No files found that match the pattern";
# on Windows, listing examples/a.zip as a directory with a '*' wildcard
# surfaces a Win32 "The parameter is incorrect" error instead.
statement error
select * from read_csv('zip://examples/a.zip/*.csv', union_by_name = true);
----

# No .zip
statement error
select * from read_csv('zip://examples/README.md!!*.csv', union_by_name = true);
----
IO Error: Could not open as zip file: failed finding central directory

query IIII
select * from read_csv('zip://examples/csv_only.zip', union_by_name = true);
----
1	2	3	NULL
4	5	6	NULL
7	8	9	NULL
99	NULL	NULL	NULL
98	NULL	NULL	NULL
97	NULL	NULL	NULL
NULL	NULL	NULL	world

query IIII
select * from read_csv('zip://examples/csv_only.zip!!', union_by_name = true);
----
1	2	3	NULL
4	5	6	NULL
7	8	9	NULL
99	NULL	NULL	NULL
98	NULL	NULL	NULL
97	NULL	NULL	NULL
NULL	NULL	NULL	world

# No files match within the zip file. With zipfs_split="!!" this path is not
# intercepted by zipfs and falls through to DuckDB's core globber. Platforms
# differ: non-Windows reports "No files found that match the pattern"; Windows
# reports "Failed to list directory ... The parameter is incorrect".
statement error
select * from read_csv('zip://examples/empty.zip');
----

statement ok
SET zipfs_split = NULL;
